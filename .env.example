# ---------------------------------------------------
# PayNexus - Environment Variables
# Copy this file to ".env" and fill in your own values
# ---------------------------------------------------

# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example:   mysql://root:password@localhost:3306/paynexus
# Free cloud DB example (Aiven / Railway): mysql://avnadmin:xxxx@host:port/defaultdb
DATABASE_URL="mysql://root:password@localhost:3306/paynexus"

# Used to sign login session JWT tokens. Use any long random string.
JWT_SECRET="replace-this-with-a-long-random-secret-string"

# Public base URL of the deployed app (used for shareable invoice links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
